mn":204},"source":"components/Block.js","original":{"line":69,"column":14}},{"generated":{"line":109,"column":222},"source":"components/Block.js","original":{"line":66,"column":6}},{"generated":{"line":109,"column":223},"source":"components/Block.js","original":{"line":65,"column":4}},{"generated":{"line":110,"column":0},"source":"components/Block.js","original":{"line":72,"column":3}},{"name":"Component","generated":{"line":114,"column":2},"source":"components/Block.js","original":{"line":6,"column":20}},{"name":"Block","generated":{"line":116,"column":15},"source":"components/Block.js","original":{"line":75,"column":15}}],"sources":{"components/Block.js":"import React, { Component } from 'react';\r\nimport Transaction from './Transaction.js';\r\nimport { Button } from 'react-bootstrap';\r\n\r\n\r\nclass Block extends Component {\r\n  state = { displayTransaction : false };\r\n\r\n  toggleTransaction = () => {\r\n    this.setState({ displayTransaction: !this.state.displayTransaction });\r\n  }\r\n\r\n  get displayTransaction() {\r\n    const { data } = this.props.block;\r\n\r\n    const stringifyData = JSON.stringify(data);\r\n\r\n    const dataDisplay = stringifyData.length > 15 ?\r\n      `${stringifyData.substring(0, 15)}...` :\r\n      stringifyData;\r\n\r\n    if (this.state.displayTransaction) {\r\n      return (\r\n        <div>\r\n          {\r\n            data.map(transaction => (\r\n              <div key={transaction.id}>\r\n                <hr/>\r\n                <Transaction transaction={transaction} />\r\n              </div>\r\n            ))\r\n          }\r\n          <br/>\r\n          <Button\r\n            bsStyle=\"danger\"\r\n            bsSize=\"small\"\r\n            onClick={this.toggleTransaction}\r\n          >\r\n            Show less\r\n          </Button>\r\n        </div>\r\n      );\r\n    }\r\n\r\n    return (\r\n      <div>\r\n        <div>Data : {dataDisplay}</div>\r\n        <br/>\r\n        <Button\r\n          bsStyle=\"danger\"\r\n          bsSize=\"small\"\r\n          onClick={this.toggleTransaction}\r\n        >\r\n          Show more\r\n        </Button>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  render() {\r\n    const { timestamp, hash } = this.props.block;\r\n\r\n    const hashDisplay = `${hash.substring(0, 15)}...`;\r\n\r\n    return (\r\n      <div className='Block'>\r\n        <div>Hash : {hashDisplay}</div>\r\n        <div>Timestamp : {new Date(timestamp).toLocaleString()}</div>\r\n        {this.displayTransaction}\r\n      </div>\r\n    );\r\n  }\r\n}\r\n\r\nexport default Block;"},"lineCount":null}},"error":null,"hash":"5a20dbe7dacf8152e53e4bf8bdec46b0","cacheData":{"env":{}}}